# Comma-separated list of dates (DD/MM/YYYY, DD-MM-YYYY, or YYYY-MM-DD)
DATES=11/04/2026,12/04/2026

# Desired session length in hours (can be fractional, e.g. 1.5)
SESSION_LENGTH_HOURS=2

# Time window to search within (24-hour HH:MM format, Melbourne time)
WINDOW_START=12:00
WINDOW_END=17:00

# --- Email notification (optional) ---
# Leave SMTP_HOST blank to skip sending email entirely.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password
EMAIL_TO=recipient@example.com
EMAIL_SUBJECT=Court Availability Suggestions

# --- GitHub Actions schedule gate (optional locally) ---
# Used by `src/time_gate.py` in GitHub Actions. Defaults shown.
RUN_ENABLED=true
RUN_TZ=Australia/Melbourne
RUN_DAYS=thu,fri
RUN_START_HOUR=8
RUN_END_HOUR=12